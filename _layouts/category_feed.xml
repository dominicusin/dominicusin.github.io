---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" 
  xmlns:atom="http://www.w3.org/2005/Atom"
  xmlns:dc="http://purl.org/dc/elements/1.1/">
  <channel>
    <title>{{ site.title }} - {{ page.title | xml_escape }} Feed</title>
    <description>{{ site.description }} - All posts in {{ page.title | xml_escape }}</description>
    <link>{{ site.url }}/categories/{{ page.category | slugify }}/</link>
    <atom:link href="{{ site.url }}/categories/{{ page.category | slugify }}/feed.xml" rel="self" type="application/rss+xml" />
    <language>{{ site.lang }}</language>
    <copyright>{{ site.time | date: "%Y" }} {{ site.author.name }}</copyright>
    <pubDate>{{ site.time | date_to_rfc822 }}</pubDate>
    <lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>
    <generator>Jekyll v{{ jekyll.version }}</generator>
    
    {% assign category_posts = site.categories[page.category] %}
    {% for post in category_posts %}
      <item>
        <title>{{ post.title | xml_escape }}</title>
        <link>{{ post.url | absolute_url }}</link>
        <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
        <author>
          <name>{{ post.author | default: site.author.name | xml_escape }}</name>
        </author>
        <guid isPermaLink="true">{{ post.url | absolute_url }}</guid>
        <description><![CDATA[{{ post.excerpt | strip_html | truncate: 300 | xml_escape }}]]></description>
        <content:encoded><![CDATA[{{ post.content }}]]></content:encoded>
        
        {% if post.image %}
        <enclosure url="{{ post.image | absolute_url }}" 
                  type="image/jpeg" />
        {% endif %}
        
        {% for tag in post.tags %}
        <category domain="{{ site.url }}/tags/{{ tag | slugify }}/">{{ tag | xml_escape }}</category>
        {% endfor %}
      </item>
    {% endfor %}
  </channel>
</rss>