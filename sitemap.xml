---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9" 
        xmlns:xhtml="http://www.w3.org/1999/xhtml"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1">
  
  <!-- Homepage -->
  <url>
    <loc>{{ site.url }}/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
    <xhtml:link rel="alternate" hreflang="en" href="{{ site.url }}/" />
    <xhtml:link rel="alternate" hreflang="ru" href="{{ site.url }}/ru/" />
  </url>
  
  <!-- About page -->
  <url>
    <loc>{{ site.url }}/about/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
    <xhtml:link rel="alternate" hreflang="en" href="{{ site.url }}/about/" />
    <xhtml:link rel="alternate" hreflang="ru" href="{{ site.url }}/ru/about/" />
  </url>
  
  <!-- Archive page -->
  <url>
    <loc>{{ site.url }}/archive/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
    <xhtml:link rel="alternate" hreflang="en" href="{{ site.url }}/archive/" />
    <xhtml:link rel="alternate" hreflang="ru" href="{{ site.url }}/ru/archive/" />
  </url>
  
  <!-- Categories page -->
  <url>
    <loc>{{ site.url }}/categories/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
    <xhtml:link rel="alternate" hreflang="en" href="{{ site.url }}/categories/" />
    <xhtml:link rel="alternate" hreflang="ru" href="{{ site.url }}/ru/categories/" />
  </url>
  
  <!-- Tags page -->
  <url>
    <loc>{{ site.url }}/tags/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
    <xhtml:link rel="alternate" hreflang="en" href="{{ site.url }}/tags/" />
    <xhtml:link rel="alternate" hreflang="ru" href="{{ site.url }}/ru/tags/" />
  </url>
  
  <!-- Category pages -->
  {% for category in site.categories %}
    <url>
      <loc>{{ site.url }}/categories/{{ category | first | slugify }}/</loc>
      <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
      <changefreq>weekly</changefreq>
      <priority>0.6</priority>
      <xhtml:link rel="alternate" hreflang="en" href="{{ site.url }}/categories/{{ category | first | slugify }}/" />
      <xhtml:link rel="alternate" hreflang="ru" href="{{ site.url }}/ru/categories/{{ category | first | slugify }}/" />
    </url>
  {% endfor %}
  
  <!-- Tag pages -->
  {% for tag in site.tags %}
    <url>
      <loc>{{ site.url }}/tags/{{ tag | first | slugify }}/</loc>
      <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
      <changefreq>monthly</changefreq>
      <priority>0.5</priority>
      <xhtml:link rel="alternate" hreflang="en" href="{{ site.url }}/tags/{{ tag | first | slugify }}/" />
      <xhtml:link rel="alternate" hreflang="ru" href="{{ site.url }}/ru/tags/{{ tag | first | slugify }}/" />
    </url>
  {% endfor %}
  
  <!-- Blog posts -->
  {% for post in site.posts %}
    <url>
      <loc>{{ post.url | absolute_url }}</loc>
      <lastmod>{{ post.last_modified_at | default: post.date | date_to_xmlschema }}</lastmod>
      <changefreq>monthly</changefreq>
      <priority>0.8</priority>
      <xhtml:link rel="alternate" hreflang="en" href="{{ post.url | absolute_url }}" />
      <xhtml:link rel="alternate" hreflang="ru" href="{{ post.url | absolute_url | replace: '/', '/ru/' }}" />
      
      {% if post.image %}
      <image:image>
        <image:loc>{{ post.image | absolute_url }}</image:loc>
        <image:title>{{ post.title | xml_escape }}</image:title>
        {% if post.image_alt %}
        <image:caption>{{ post.image_alt | xml_escape }}</image:caption>
        {% endif %}
      </image:image>
      {% endif %}
    </url>
  {% endfor %}
  
  <!-- Static assets -->
  <url>
    <loc>{{ site.url }}/css/main.css</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.3</priority>
  </url>
  
  <url>
    <loc>{{ site.url }}/js/i18n.js</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.3</priority>
  </url>
  
  <url>
    <loc>{{ site.url }}/js/interactive.js</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.3</priority>
  </url>
  
  <url>
    <loc>{{ site.url }}/assets/i18n/en.json</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.2</priority>
  </url>
  
  <url>
    <loc>{{ site.url }}/assets/i18n/ru.json</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.2</priority>
  </url>
  
  <url>
    <loc>{{ site.url }}/manifest.json</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.2</priority>
  </url>
  
</urlset>